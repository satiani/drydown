# Example Home Assistant `customize` block for drydown.
#
# Pot size is NOT set in drydown.yaml — it is attached as an attribute to each
# source moisture entity here, in /config/configuration.yaml, and read at
# runtime. drydown uses it to pick the adaptive moisture-jump threshold
# (small 15, medium 8, large 5).
#
# Copy this block under the existing `homeassistant:` key in your
# configuration.yaml, one entry per plant moisture sensor you configured in
# apps/drydown/drydown.yaml. Pot size must be one of: small, medium, large.
#
# homeassistant:
#   customize:
#     sensor.plant_sensor_1_moisture:
#       pot_size: medium
#     sensor.plant_sensor_2_moisture:
#       pot_size: small
#     sensor.plant_sensor_3_moisture:
#       pot_size: medium
#     sensor.plant_sensor_4_moisture:
#       pot_size: large
#     sensor.plant_sensor_5_moisture:
#       pot_size: large
#     sensor.plant_sensor_6_moisture:
#       pot_size: medium
#     sensor.living_room_plant_sensor_7_moisture:
#       pot_size: medium
#     sensor.kitchen_plant_sensor_8_moisture:
#       pot_size: medium
#     sensor.kitchen_plant_sensor_9_moisture:
#       pot_size: medium
homeassistant:
  customize: {}
